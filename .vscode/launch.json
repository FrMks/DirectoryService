{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "DirectoryService (ASP.NET Core)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-directoryservice",
            "program": "${workspaceFolder}/backend/src/DirectoryService.Presentation/bin/Debug/net9.0/DirectoryService.Presentation.dll",
            "args": [],
            "cwd": "${workspaceFolder}/backend/src/DirectoryService.Presentation",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5142"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        }
    ]
}
