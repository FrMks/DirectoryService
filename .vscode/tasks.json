{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-directoryservice",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/backend/DirectoryService.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "watch-directoryservice",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/backend/src/DirectoryService/DirectoryService.Presentation/DirectoryService.Presentation.csproj",
                "--urls",
                "http://localhost:5142"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
